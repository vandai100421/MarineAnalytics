# ─────────────────────────────────────────────
# MarineAnalytics — Environment Variables
# Copy file này thành .env rồi điền giá trị thật
# KHÔNG commit .env thật vào git
# ─────────────────────────────────────────────

# AISStream.io API key (đăng ký free tại https://aisstream.io/)
AISSTREAM_API_KEY=your_aisstream_api_key_here

# Bounding box mặc định khi subscribe AISStream (min_lon,min_lat,max_lon,max_lat)
# Để trống để lấy toàn cầu. Ví dụ Biển Đông: 104,0,122,25
AISSTREAM_BBOX=

# PostgreSQL + TimescaleDB
POSTGRES_USER=marine
POSTGRES_PASSWORD=marine
POSTGRES_DB=marineanalytics
POSTGRES_PORT=5432

# Backend DATABASE_URL (asyncpg driver). Khi chạy trong docker-compose,
# sẽ được override thành connection string tới container timescaledb.
DATABASE_URL=postgresql+asyncpg://marine:marine@localhost:5432/marineanalytics

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# Realtime SSE
SSE_BATCH_INTERVAL_SECONDS=1
SSE_HEARTBEAT_SECONDS=15
SSE_MAX_CLIENTS=200

# Ingestion
INGESTION_FLUSH_INTERVAL_SECONDS=2
INGESTION_BATCH_SIZE=200

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
# Map style URL (MapLibre GL style JSON). Mặc định dùng OpenStreetMap local.
# Đổi sang tile server khác (self-hosted, CARTO, MapTiler...) nếu cần.
VITE_MAP_STYLE_URL=/styles/osm-style.json

# ADSBExchange (Phase 2, để trống nếu chưa dùng)
ADSBEXCHANGE_API_KEY=
